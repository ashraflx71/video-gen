<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ashraf Video Gen 2026</title>
    <style>
        :root { --primary: #ffd700; --bg: #121212; --card: #1e1e1e; --text: #e0e0e0; }
        body { background-color: var(--bg); color: var(--text); font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; padding: 20px; display: flex; flex-direction: column; align-items: center; }
        .container { background: var(--card); padding: 25px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); width: 100%; max-width: 500px; border: 1px solid #333; }
        h2 { color: var(--primary); margin-bottom: 20px; font-weight: 300; }
        textarea { width: 100%; height: 120px; background: #2c2c2c; border: 1px solid #444; border-radius: 12px; color: white; padding: 15px; box-sizing: border-box; font-size: 16px; resize: none; margin-bottom: 15px; }
        .file-upload { margin-bottom: 20px; font-size: 14px; }
        button { background: linear-gradient(45deg, #ffd700, #ff8c00); color: #000; border: none; padding: 15px 40px; border-radius: 50px; cursor: pointer; font-size: 18px; font-weight: bold; transition: 0.3s; width: 100%; box-shadow: 0 5px 15px rgba(255, 215, 0, 0.3); }
        button:active { transform: scale(0.95); }
        #videoContainer { margin-top: 25px; display: none; width: 100%; }
        video { width: 100%; border-radius: 15px; border: 2px solid var(--primary); box-shadow: 0 0 20px rgba(255, 215, 0, 0.2); }
        .status { margin-top: 15px; font-size: 14px; color: #888; }
        .logo-text { font-size: 12px; color: var(--primary); letter-spacing: 2px; margin-top: 10px; }
    </style>
</head>
<body>

    <div class="container">
        <h2>Creative 2026 🎬</h2>
        <textarea id="inputText" placeholder="اكتب نص الفيديو هنا يا هندسة..."></textarea>
        
        <div class="file-upload">
            <label>اختر صورة الخلفية: </label>
            <input type="file" id="bgImage" accept="image/*">
        </div>

        <button onclick="startProcessing()">توليد الفيديو الآن 🚀</button>
        
        <div id="videoContainer">
            <video id="previewVideo" controls></video>
            <p style="margin-top:10px;">جاهز للتحميل! 👆</p>
        </div>

        <div class="status" id="statusText">جاهز للعمل..</div>
        <div class="logo-text">ASHRAF HASSAN • OPTIMUM SEO</div>
    </div>

    <canvas id="videoCanvas" width="720" height="1280" style="display:none;"></canvas>

    <script>
        async function startProcessing() {
            const text = document.getElementById('inputText').value;
            const canvas = document.getElementById('videoCanvas');
            const ctx = canvas.getContext('2d');
            const status = document.getElementById('statusText');
            const imageInput = document.getElementById('bgImage');
            const videoContainer = document.getElementById('videoContainer');
            const previewVideo = document.getElementById('previewVideo');
            
            if(!text) return alert("من فضلك اكتب نصاً أولاً");

            status.innerText = "جاري تحضير المحرك الصوتي... ✨";
            
            const utterance = new SpeechSynthesisUtterance(text);
            utterance.lang = 'ar-SA';
            utterance.rate = 0.9;

            const stream = canvas.captureStream(30);
            const recorder = new MediaRecorder(stream, { mimeType: 'video/webm;codecs=vp9' });
            const chunks = [];
            
            recorder.ondataavailable = e => chunks.push(e.data);
            recorder.onstop = () => {
                const blob = new Blob(chunks, { type: 'video/webm' });
                const url = URL.createObjectURL(blob);
                previewVideo.src = url;
                videoContainer.style.display = 'block';
                status.innerText = "تم التوليد بنجاح! ✅";
                
                // تحميل تلقائي
                const a = document.createElement('a');
                a.href = url;
                a.download = 'Creative2026_Video.webm';
                a.click();
            };

            let img = new Image();
            if(imageInput.files[0]) img.src = URL.createObjectURL(imageInput.files[0]);
            
            utterance.onstart = () => {
                recorder.start();
                animate();
            };

            utterance.onend = () => {
                setTimeout(() => recorder.stop(), 1000);
            };

            function animate() {
                if (recorder.state === "recording") {
                    ctx.fillStyle = "#121212";
                    ctx.fillRect(0, 0, canvas.width, canvas.height);
                    if(img.src) ctx.drawImage(img, 0, 0, canvas.width, canvas.height);

                    // طبقة شفافة للنص
                    ctx.fillStyle = "rgba(0,0,0,0.4)";
                    ctx.fillRect(50, canvas.height/2 - 200, canvas.width - 100, 400);

                    ctx.fillStyle = "#ffd700";
                    ctx.font = "bold 45px Arial";
                    ctx.textAlign = "center";
                    wrapText(ctx, text, canvas.width/2, canvas.height/2 - 100, canvas.width - 150, 60);
                    
                    requestAnimationFrame(animate);
                }
            }

            window.speechSynthesis.speak(utterance);
        }

        function wrapText(context, text, x, y, maxWidth, lineHeight) {
            var words = text.split(' ');
            var line = '';
            for(var n = 0; n < words.length; n++) {
                var testLine = line + words[n] + ' ';
                if (context.measureText(testLine).width > maxWidth && n > 0) {
                    context.fillText(line, x, y);
                    line = words[n] + ' ';
                    y += lineHeight;
                } else { line = testLine; }
            }
            context.fillText(line, x, y);
        }
    </script>
</body>
</html>
